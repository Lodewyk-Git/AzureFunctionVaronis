                  "type": "string"
                }
              ],
              "metadata": {
                "description": "Custom table columns to enforce."
              }
            },
            "tableRetentionInDays": {
              "type": "int",
              "defaultValue": 30,
              "metadata": {
                "description": "Table retention in days."
              }
            },
            "tableTotalRetentionInDays": {
              "type": "int",
              "defaultValue": 90,
              "metadata": {
                "description": "Table total retention in days."
              }
            },
            "createDataCollectionEndpoint": {
              "type": "bool",
              "defaultValue": true,
              "metadata": {
                "description": "Create Data Collection Endpoint. Keep true for stable Logs Ingestion endpoint behavior."
              }
            },
            "dcrDataSenderRoleDefinitionId": {
              "type": "string",
              "defaultValue": "3913510d-42f4-4e42-8a64-420c390055eb",
              "metadata": {
                "description": "Data Collection Rule Data Sender role definition ID. Defaults to Monitoring Metrics Publisher."
              }
            }
          },
          "variables": {
            "uniqueSuffix": "[toLower(uniqueString(resourceGroup().id, parameters('environmentName'), parameters('tableName')))]",
            "workspaceName": "[last(split(parameters('workspaceResourceId'), '/'))]",
            "workspaceSubscriptionId": "[split(parameters('workspaceResourceId'), '/')[2]]",
            "workspaceResourceGroupName": "[split(parameters('workspaceResourceId'), '/')[4]]",
            "dceName": "[take(format('{0}-{1}-dce-{2}', parameters('namePrefix'), parameters('environmentName'), variables('uniqueSuffix')), 60)]",
            "dcrName": "[take(format('{0}-{1}-dcr-{2}', parameters('namePrefix'), parameters('environmentName'), variables('uniqueSuffix')), 60)]"
          },
          "resources": [
            {
              "type": "Microsoft.OperationalInsights/workspaces/tables",
              "apiVersion": "2023-09-01",
              "name": "[format('{0}/{1}', variables('workspaceName'), parameters('tableName'))]",
              "properties": {
                "plan": "Analytics",
                "retentionInDays": "[parameters('tableRetentionInDays')]",
                "totalRetentionInDays": "[parameters('tableTotalRetentionInDays')]",
                "schema": {
                  "name": "[parameters('tableName')]",
                  "columns": "[parameters('tableColumns')]"
                }
              }
            },
            {
              "condition": "[parameters('createDataCollectionEndpoint')]",
              "type": "Microsoft.Insights/dataCollectionEndpoints",
              "apiVersion": "2023-03-11",
              "name": "[variables('dceName')]",
              "location": "[parameters('location')]",
              "kind": "Linux",
              "tags": {
                "Environment": "[parameters('environmentName')]",
                "Owner": "[parameters('ownerEmail')]",
                "Workload": "AzureFunctionVaronis"
              },
              "properties": {
                "networkAcls": {
                  "publicNetworkAccess": "Enabled"
                }
              }
            },
            {
              "type": "Microsoft.Insights/dataCollectionRules",
              "apiVersion": "2023-03-11",
              "name": "[variables('dcrName')]",
              "location": "[parameters('location')]",
              "kind": "Direct",
              "tags": {
                "Environment": "[parameters('environmentName')]",
                "Owner": "[parameters('ownerEmail')]",
                "Workload": "AzureFunctionVaronis"
              },
              "properties": {
                "dataCollectionEndpointId": "[if(parameters('createDataCollectionEndpoint'), resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName')), null())]",
                "streamDeclarations": {
                  "[format('{0}', parameters('streamName'))]": {
                    "columns": "[parameters('tableColumns')]"
                  }
                },
                "destinations": {
                  "logAnalytics": [
                    {
                      "name": "logAnalyticsDestination",
                      "workspaceResourceId": "[parameters('workspaceResourceId')]"
                    }
                  ]
                },
                "dataFlows": [
                  {
                    "streams": [
                      "[parameters('streamName')]"
                    ],
                    "destinations": [
                      "logAnalyticsDestination"
                    ],
                    "transformKql": "source",
                    "outputStream": "[parameters('streamName')]"
                  }
                ]
              },
              "dependsOn": [
                "[resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName'))]",
                "[resourceId('Microsoft.OperationalInsights/workspaces/tables', split(format('{0}/{1}', variables('workspaceName'), parameters('tableName')), '/')[0], split(format('{0}/{1}', variables('workspaceName'), parameters('tableName')), '/')[1])]"
              ]
            },
            {
              "type": "Microsoft.Authorization/roleAssignments",
              "apiVersion": "2022-04-01",
              "scope": "[resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName'))]",
              "name": "[guid(resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName')), parameters('functionPrincipalId'), parameters('dcrDataSenderRoleDefinitionId'))]",
              "properties": {
                "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', parameters('dcrDataSenderRoleDefinitionId'))]",
                "principalId": "[parameters('functionPrincipalId')]",
                "principalType": "ServicePrincipal"
              },
              "dependsOn": [
                "[resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName'))]"
              ]
            }
          ],
          "outputs": {
            "tableName": {
              "type": "string",
              "value": "[parameters('tableName')]"
            },
            "streamName": {
              "type": "string",
              "value": "[parameters('streamName')]"
            },
            "dcrResourceId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName'))]"
            },
            "dcrImmutableId": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', variables('dcrName')), '2023-03-11').immutableId]"
            },
            "dceResourceId": {
              "type": "string",
              "value": "[if(parameters('createDataCollectionEndpoint'), resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName')), '')]"
            },
            "logsIngestionEndpoint": {
              "type": "string",
              "value": "[if(parameters('createDataCollectionEndpoint'), reference(resourceId('Microsoft.Insights/dataCollectionEndpoints', variables('dceName')), '2023-03-11', 'full').properties.logsIngestion.endpoint, '')]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'coreDeployment')]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'coreDeployment'), '2025-04-01').outputs.functionAppName.value]"
    },
    "functionAppResourceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'coreDeployment'), '2025-04-01').outputs.functionAppResourceId.value]"
    },
    "packageStorageAccountName": {
      "type": "string",
