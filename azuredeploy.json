    },
    "dcrResourceId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'monitoringDeployment'), '2025-04-01').outputs.dcrResourceId.value]"
    },
    "dcrImmutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'monitoringDeployment'), '2025-04-01').outputs.dcrImmutableId.value]"
    },
    "dceResourceId": {
