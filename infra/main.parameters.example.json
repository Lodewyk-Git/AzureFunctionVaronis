{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "eastus2"
    },
    "environmentName": {
      "value": "dev"
    },
    "namePrefix": {
      "value": "varonis"
    },
    "ownerEmail": {
      "value": "Lood@buisecops.co.za"
    },
    "workspaceResourceId": {
      "value": "/subscriptions/<subscription-id>/resourceGroups/<resource-group>/providers/Microsoft.OperationalInsights/workspaces/<sentinel-enabled-workspace-name>"
    },
    "appInsightsWorkspaceResourceId": {
      "value": ""
    },
    "timerSchedule": {
      "value": "0 */5 * * * *"
    },
    "runFromPackageValue": {
      "value": "https://github.com/Lodewyk-Git/AzureFunctionVaronis/releases/latest/download/varonis-sentinel-functions.zip"
    },
    "tableName": {
      "value": "VaronisAlerts_CL"
    },
    "streamName": {
      "value": "Custom-VaronisAlerts_CL"
    },
    "functionPlanSkuName": {
      "value": "Y1"
    },
    "functionPlanSkuTier": {
      "value": "Dynamic"
    },
    "enableDiagnostics": {
      "value": true
    }
  }
}
